# CodeSentinel local demo environment.

# Keep true for the hackathon demo. Seeded data is loaded in memory:
# - cto@acme.test
# - finance.employee@acme.test -> cs_demo_finance
# - support.employee@acme.test -> cs_demo_support
CODESENTINEL_DEMO_MODE=true

# Local ingest URL used in docs and scripts.
CODESENTINEL_INGEST_URL=http://localhost:3000/api/ingest
CODESENTINEL_BASE_URL=http://localhost:3000

# When true, a matching PreToolUse event with action=block returns Claude
# permissionDecision=deny. Default demo mode is dashboard-only.
CS_BLOCK_CRITICAL=false

# Optional future LLM enrichment. The current MVP Risk Engine is deterministic
# and does not require this key.
ANTHROPIC_API_KEY=

# Later, when Supabase/Postgres is added.
DATABASE_URL=
